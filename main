local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local VirtualInputManager = game:GetService("VirtualInputManager")

-- CONFIGURATION
local PARRY_KEY = Enum.KeyCode.F
local DETECTION_RANGE = 15 -- Radius of the red ring

-- COOLDOWN AND TIMER RULES
local SUCCESS_COOLDOWN = 90
local FAIL_COOLDOWN = 60
local PARRY_WINDOW = 0.8

local IsAutoParryActive = true
local currentCooldown = 0
local lastParryTime = 0
local isWaitingForResult = false

-- 1. CREATE VISUAL RING UNDER FEET
local function createDetectionRing(character)
    local hrp = character:WaitForChild("HumanoidRootPart")
    if hrp:FindFirstChild("DetectionRing") then
        hrp.DetectionRing:Destroy()
    end
    
    local ring = Instance.new("CylinderHandleAdornment")
    ring.Name = "DetectionRing"
    ring.Radius = DETECTION_RANGE
    ring.InnerRadius = DETECTION_RANGE - 0.3
    ring.Height = 0.1
    ring.Color3 = Color3.fromRGB(255, 0, 0) -- Neon Red
    ring.AlwaysOnTop = false
    ring.ZIndex = 5
    ring.Adornee = hrp
    ring.CFrame = CFrame.new(0, -2.5, 0) * CFrame.Angles(math.rad(90), 0, 0)
    ring.Parent = hrp
end

if LocalPlayer.Character then createDetectionRing(LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(createDetectionRing)

-- 2. PARRY TRIGGER FUNCTION
local function performParry(enemyAttackedImmediately)
    lastParryTime = tick()
    isWaitingForResult = true
    
    -- Press key to trigger 1-second defense
    VirtualInputManager:SendKeyEvent(true, PARRY_KEY, false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, PARRY_KEY, false, game)
    print("🛡️ Defensive state activated for 1 second!")

    if enemyAttackedImmediately then
        currentCooldown = SUCCESS_COOLDOWN
        isWaitingForResult = false
        print("🎯 SUCCESS! Attack blocked. Cooldown: " .. SUCCESS_COOLDOWN .. "s")
    else
        task.delay(PARRY_WINDOW, function()
            if isWaitingForResult then
                isWaitingForResult = false
                currentCooldown = FAIL_COOLDOWN
                print("❌ FAIL! No attack within 0.8s window. Cooldown: " .. FAIL_COOLDOWN .. "s")
            end
        end)
    end
end

-- 3. VFX DETECTION FOR SUCCESSFUL STUN
local function setupVfxDetection(character)
    character.DescendantAdded:Connect(function(desc)
        if isWaitingForResult and (tick() - lastParryTime <= PARRY_WINDOW) then
            if desc:IsA("ParticleEmitter") or desc:IsA("MeshPart") or desc:IsA("SpecialMesh") then
                local name = string.lower(desc.Name)
                if string.find(name, "vfx") or string.find(name, "parry") or string.find(name, "slash") or string.find(name, "red") then
                    currentCooldown = SUCCESS_COOLDOWN
                    isWaitingForResult = false
                    print("🎯 SUCCESS! Red slash VFX caught inside 0.8s. Cooldown: " .. SUCCESS_COOLDOWN .. "s")
                end
            end
        end
    end)
end

if LocalPlayer.Character then setupVfxDetection(LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(setupVfxDetection)

-- 4. NEW LOGIC: DETECT KILLER ANIMATIONS DIRECTLY
RunService.Heartbeat:Connect(function()
    if not IsAutoParryActive then return end
    
    local character = LocalPlayer.Character
    if not character or (tick() - lastParryTime < currentCooldown) then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    for _, enemy in pairs(Players:GetPlayers()) do
        if enemy ~= LocalPlayer and enemy.Character then
            local enemyHrp = enemy.Character:FindFirstChild("HumanoidRootPart")
            local enemyHumanoid = enemy.Character:FindFirstChildOfClass("Humanoid")
            
            if enemyHrp and enemyHumanoid and enemyHumanoid.Health > 0 then
                local distance = (hrp.Position - enemyHrp.Position).Magnitude
                
                -- Check distance
                if distance <= DETECTION_RANGE then
                    -- Get Killer's Animator to see if they are swinging the sword
                    local enemyAnimator = enemyHumanoid:FindFirstChildOfClass("Animator")
                    if enemyAnimator then
                        local playingTracks = enemyAnimator:GetPlayingAnimationTracks()
                        local isAttacking = false
                        
                        -- If Killer is playing ANY custom animation (not idle, walk, run)
                        for _, track in pairs(playingTracks) do
                            local animName = string.lower(track.Animation.Name or "")
                            local animId = track.Animation.AnimationId
                            
                            -- Ignore basic movement animations
                            if not string.find(animName, "idle") and not string.find(animName, "walk") and not string.find(animName, "run") then
                                isAttacking = true
                                break
                            end
                        end
                        
                        -- Trigger if Killer attacks inside the ring
                        if isAttacking then
                            if not isWaitingForResult then
                                performParry(true)
                                break
                            elseif isWaitingForResult and (tick() - lastParryTime <= PARRY_WINDOW) then
                                currentCooldown = SUCCESS_COOLDOWN
                                isWaitingForResult = false
                                print("🎯 SUCCESS! Intercepted within 0.8s. Cooldown: " .. SUCCESS_COOLDOWN .. "s")
                                break
                            end
                        end
                    end
                end
            end
        end
    end
end)

print("🚀 Animation-Based Auto Parry Loaded! Distance Ring Active.")
